    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.4",
    "jsdom": "^25.0.1",
    "oxlint": "^1.71.0",
    "postcss": "^8.5.21",
